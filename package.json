{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "chrome-find",
  "title": "Find in Chrome",
  "description": "Unified search across Chrome tabs, bookmarks, and history. Finds existing tabs and switches to them, or opens from bookmarks/history.",
  "icon": "extension-icon.png",
  "author": "albert_dabinski",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "find-in-chrome",
      "title": "Find in Chrome",
      "subtitle": "Tabs → Bookmarks → History",
      "description": "Search across open tabs, bookmarks, and browsing history in one unified list",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^2.2.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.4",
    "@types/react": "19.0.8",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "overrides": {
    "minimatch": "^9.0.7"
  }
}
